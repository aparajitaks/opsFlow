# =========================================================================
# opsFlow Configuration Variables Template
# Copy this file to .env and substitute values for local execution
# =========================================================================

# Groq Cloud API credentials for answering questions and audits
# (Request keys at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Generator & Claim Auditing LLM models configuration
GROQ_MODEL_GENERATOR=llama-3.1-8b-instant
GROQ_MODEL_AUDITOR=llama-3.1-8b-instant

# Security rate limits
RATE_LIMIT_PER_MINUTE=60.0
MAX_QUERY_LENGTH=2000
