# Copy to .env and fill in values

# Required for live LLM answers (Task 4). Get a key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides
GROQ_MODEL_GENERATOR=llama-3.1-8b-instant
GROQ_MODEL_AUDITOR=llama-3.1-8b-instant
RATE_LIMIT_PER_MINUTE=60
MAX_QUERY_LENGTH=2000
ML_N_JOBS=-1
